# Secrets — never commit these
.env

# Build output. NOTE: dist/ is intentionally COMMITTED so the host (Render)
# can run the compiled JS without needing the .NET/Fable build toolchain.
# Rebuild with `npm run build` and commit dist/ before deploying.
bin/
obj/
.fable/

# Dependencies
node_modules/

# Runtime data
logs/*.log
database/*.json
database/*.sqlite
database/*.db
database/backups/

# OS noise
Thumbs.db
.DS_Store
logs/*.out

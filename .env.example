# ── Telegram ────────────────────────────────────────────────
# Get this from @BotFather in Telegram: /newbot
BOT_TOKEN=

# ── DeepSeek ────────────────────────────────────────────────
# Get an API key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── App ─────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# ── Cloud durability (production only) ──────────────────────
# Neon Postgres connection string. When set, on boot the bot restores its
# SQLite database from a snapshot in Neon, and snapshots back every ~2 min and
# on shutdown — so an ephemeral-disk host (Render free tier) keeps its data.
# Leave BLANK locally to just use the local database/ file.
DATABASE_URL=
# PORT is provided automatically by the host (Render); do not set it yourself.

# Telegram user id allowed to use /admin (optional; find yours via @userinfobot)
ADMIN_USER_ID=

# ── Vision (photo food logging, optional) ───────────────────
# Any OpenAI-compatible vision endpoint works. Recommended FREE option:
# Google AI Studio — create a key at https://aistudio.google.com/apikey
# and paste it below; the defaults target Gemini's OpenAI-compatible API.
# Groq alternative: VISION_BASE_URL=https://api.groq.com/openai/v1
#                   VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# A real AI Studio key starts with "AIza".
VISION_API_KEY=
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_MODEL=gemini-2.5-flash
